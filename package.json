{
  "name": "pi-antigravity-rotator",
  "version": "2.3.1",
  "description": "Multi-account rotation proxy for Google Antigravity with per-model routing, real-time quota tracking, and infringement detection",
  "license": "MIT",
  "type": "module",
  "bin": {
    "pi-antigravity-rotator": "bin/pi-antigravity-rotator.js"
  },
  "scripts": {
    "start": "tsx src/cli.ts start",
    "login": "tsx src/cli.ts login",
    "typecheck": "tsc --noEmit",
    "test": "PI_ROTATOR_DIR=/tmp/pi-rotator-test node --import tsx/esm --test \"test/**/*.test.ts\"",
    "lint": "eslint src test",
    "coverage": "c8 --reporter=text --reporter=html npm test",
    "check": "npm run typecheck && npm test && npm run lint"
  },
  "files": [
    "bin/",
    "src/",
    "tools/telemetry-receiver/",
    "CHANGELOG.md",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "pi-package",
    "pi",
    "pi-coding",
    "pi-coding-agent",
    "antigravity",
    "proxy",
    "rotation",
    "google",
    "quota",
    "gemini"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tuxevil/pi-antigravity-rotator.git"
  },
  "author": "Sebastián Real (tuxevil)",
  "dependencies": {
    "pg": "^8.22.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.20.0",
    "c8": "^11.0.0",
    "eslint": "^10.5.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.1"
  }
}
